BACKUPS_PATH=/mnt/tank/urbackup
RESTORE_PATH=/mnt/tank/restore
PORT=8000

# TrueNAS configuration
TRUENAS_HOST=https://truenas.example.com
TRUENAS_USERNAME=truenas_admin
TRUENAS_API_KEY=your-api-key
TRUENAS_VERIFY_SSL=false
TRUENAS_TARGET_NAME=urbackup-restore-target
# TRUENAS_AUTH_MECHANISM: set to PLAIN if your TrueNAS version does not support SCRAM (before v26)
TRUENAS_AUTH_MECHANISM=SCRAM
